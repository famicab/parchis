# Puerto de escucha. En local por defecto 3001; en producción lo inyecta el host (Render → $PORT).
PORT=3001

# Origen permitido para CORS (dominio del frontend). En local no hace falta (acepta '*').
# En producción: la URL pública del cliente en Vercel, p. ej. https://parchis.vercel.app
CLIENT_ORIGIN=
